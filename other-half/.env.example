PORT=4000
JWT_SECRET=replace-with-a-strong-jwt-secret
MONGODB_URI=mongodb+srv://username:<db_password>@cluster.mongodb.net/?appName=PetPlus
MONGODB_DB_NAME=PetPlus
MONGODB_COLLECTION=appstates
MONGODB_CONNECT_TIMEOUT_MS=30000
ENABLE_DEMO_SEEDING=false
CLIENT_ORIGIN=http://localhost:5173,http://127.0.0.1:5173,https://pet-plus.co.in,https://www.pet-plus.co.in
APP_UPLOADS_DIR=app-data/uploads
VITE_API_BASE_URL=http://localhost:4000/api
VITE_SITE_URL=https://www.pet-plus.co.in
USD_TO_INR_RATE=93.29
VITE_USD_TO_INR_RATE=93.29
# Optional legacy migration source if your old db.json is not in app-data/db.json:
# APP_DATA_DIR=app-data
# Production bootstrap:
# BOOTSTRAP_ADMIN_NAME=PetPlus Admin
# BOOTSTRAP_ADMIN_EMAIL=admin@PetPlus.co.in
# BOOTSTRAP_ADMIN_PASSWORD=replace-with-a-strong-password
# AUTH_COOKIE_DOMAIN=.pet-plus.co.in
# AUTH_COOKIE_SECURE=true
# AUTH_COOKIE_SAME_SITE=lax
# SMTP mail delivery for Contact Us admin notifications:
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=notifications@PetPlus.co.in
# SMTP_PASS=replace-with-your-smtp-password
# EMAIL_USER=notifications@PetPlus.co.in
# EMAIL_PASS=replace-with-your-email-password
# MAIL_FROM=PetPlus <notifications@PetPlus.co.in>
# SUPPORT_NOTIFICATION_EMAIL=care@PetPlus.co.in
# ADMIN_NOTIFICATION_EMAIL=admin@PetPlus.co.in
# WhatsApp support widget:
# VITE_WHATSAPP_PHONE=919876543210
# VITE_WHATSAPP_MESSAGE=Hi PetPlus, I have a question about my dog's routine.
# Razorpay test credentials:
# RAZORPAY_KEY_ID=rzp_test_replace_with_your_key_id
# RAZORPAY_KEY_SECRET=replace_with_your_secret
# Cloud upload storage for production support attachments:
# CLOUDINARY_CLOUD_NAME=your-cloud-name
# CLOUDINARY_API_KEY=your-cloudinary-api-key
# CLOUDINARY_API_SECRET=your-cloudinary-api-secret
# CLOUDINARY_FOLDER=PetPlus/support-attachments
# ALLOW_LOCAL_UPLOAD_STORAGE=false
# Optional AI dog health assistant using an OpenAI-compatible API:
# OPENAI_API_KEY=replace-with-your-api-key
# OPENAI_MODEL=gpt-4.1-mini
# OPENAI_API_URL=https://api.openai.com/v1/chat/completions
