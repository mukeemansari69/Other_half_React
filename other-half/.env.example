PORT=4000
JWT_SECRET=replace-with-a-strong-jwt-secret
MONGODB_URI=mongodb+srv://username:<db_password>@cluster.mongodb.net/?appName=Other-Half
MONGODB_DB_NAME=other-half
MONGODB_COLLECTION=appstates
MONGODB_CONNECT_TIMEOUT_MS=30000
ENABLE_DEMO_SEEDING=false
CLIENT_ORIGIN=http://localhost:5173,http://127.0.0.1:5173,https://otherhalfpets.com,https://www.otherhalfpets.com
APP_UPLOADS_DIR=app-data/uploads
VITE_API_BASE_URL=http://localhost:4000/api
VITE_SITE_URL=https://www.otherhalfpets.com
# Optional legacy migration source if your old db.json is not in app-data/db.json:
# APP_DATA_DIR=app-data
# Production bootstrap:
# BOOTSTRAP_ADMIN_NAME=Other Half Admin
# BOOTSTRAP_ADMIN_EMAIL=admin@example.com
# BOOTSTRAP_ADMIN_PASSWORD=replace-with-a-strong-password
# AUTH_COOKIE_DOMAIN=.otherhalfpets.com
# AUTH_COOKIE_SECURE=true
# AUTH_COOKIE_SAME_SITE=lax
# SMTP mail delivery for Contact Us admin notifications:
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=notifications@example.com
# SMTP_PASS=replace-with-your-smtp-password
# EMAIL_USER=notifications@example.com
# EMAIL_PASS=replace-with-your-email-password
# MAIL_FROM=Other Half Pets <notifications@example.com>
# SUPPORT_NOTIFICATION_EMAIL=admin@otherhalfpets.com
# ADMIN_NOTIFICATION_EMAIL=admin@otherhalfpets.com
# Stripe test key (required for checkout):
# STRIPE_SECRET_KEY=sk_test_replace_with_your_key
# Stripe webhook signing secret (required for recurring renewal sync):
# STRIPE_WEBHOOK_SECRET=whsec_replace_with_your_webhook_secret
# Cloud upload storage for production support attachments:
# CLOUDINARY_CLOUD_NAME=your-cloud-name
# CLOUDINARY_API_KEY=your-cloudinary-api-key
# CLOUDINARY_API_SECRET=your-cloudinary-api-secret
# CLOUDINARY_FOLDER=other-half/support-attachments
# ALLOW_LOCAL_UPLOAD_STORAGE=false
# UPI fallback (used when STRIPE_SECRET_KEY is not set):
# UPI_VPA=9690296846@ptsbi
# UPI_PAYEE_NAME=Other Half Pets
