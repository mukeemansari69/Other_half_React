NODE_ENV=production
PORT=4000
CLIENT_ORIGIN=https://pet-plus.co.in,https://www.pet-plus.co.in
JWT_SECRET=replace-with-a-long-random-secret
MONGODB_URI=mongodb+srv://username:<db_password>@cluster.mongodb.net/?appName=Other-Half
MONGODB_DB_NAME=other-half
MONGODB_COLLECTION=appstates
MONGODB_CONNECT_TIMEOUT_MS=30000
ENABLE_DEMO_SEEDING=false
APP_UPLOADS_DIR=app-data/uploads
VITE_API_BASE_URL=https://pet-plus.co.in/api
VITE_SITE_URL=https://pet-plus.co.in
BOOTSTRAP_ADMIN_NAME=Pet Plus Admin
BOOTSTRAP_ADMIN_EMAIL=admin@pet-plus.co.in
BOOTSTRAP_ADMIN_PASSWORD=replace-with-a-strong-password
AUTH_COOKIE_DOMAIN=.pet-plus.co.in
AUTH_COOKIE_SECURE=true
AUTH_COOKIE_SAME_SITE=lax
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=notifications@pet-plus.co.in
SMTP_PASS=replace-with-your-smtp-password
EMAIL_USER=notifications@pet-plus.co.in
EMAIL_PASS=replace-with-your-email-password
MAIL_FROM=Pet Plus <notifications@pet-plus.co.in>
SUPPORT_NOTIFICATION_EMAIL=support@pet-plus.co.in
ADMIN_NOTIFICATION_EMAIL=admin@pet-plus.co.in
STRIPE_SECRET_KEY=sk_live_replace_with_your_key
STRIPE_WEBHOOK_SECRET=whsec_replace_with_your_webhook_secret
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret
CLOUDINARY_FOLDER=pet-plus/support-attachments
ALLOW_LOCAL_UPLOAD_STORAGE=false
